{
  "name": "betacreator-react",
  "version": "1.0.0",
  "description": "React TypeScript wrapper for the BetaCreator rock climbing route guide library",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "npm run bundle:betacreator && vite",
    "build": "npm run bundle:betacreator && tsc && vite build",
    "build:lib": "npm run bundle:betacreator && vite build --mode lib",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "bundle:betacreator": "node scripts/bundle-betacreator.js"
  },
  "keywords": [
    "react",
    "typescript",
    "rock-climbing",
    "beta",
    "route-guide",
    "canvas",
    "climbing"
  ],
  "author": "Your Name",
  "license": "Apache-2.0",
  "peerDependencies": {
    "react": "^17.0.0 || ^18.0.0",
    "react-dom": "^17.0.0 || ^18.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "eslint": "^8.45.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "typescript": "^5.0.2",
    "vite": "^4.4.5",
    "vite-plugin-dts": "^3.5.0"
  }
}